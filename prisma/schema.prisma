generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  VENDOR
  HOST
  ADMIN
  FIELD_AGENT
}

enum BookingStatus {
  PENDING
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  TIGO_PESA
  AIRTEL_MONEY
  CARD
  STRIPE
}

enum ShelfCondition {
  GOOD
  NEEDS_ATTENTION
  CRITICAL
}

enum LogisticsStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  password      String
  role          Role      @default(VENDOR)
  avatar        String?
  businessName  String?
  city          String?
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  shelves       Shelf[]           @relation("HostShelves")
  bookings      Booking[]         @relation("VendorBookings")
  reviews       Review[]
  fieldReports  FieldReport[]     @relation("AgentReports")
  notifications Notification[]
  payouts       Payout[]
  logisticsJobs LogisticsJob[]    @relation("AgentJobs")

  @@map("users")
}

model Shelf {
  id          String   @id @default(cuid())
  hostId      String
  host        User     @relation("HostShelves", fields: [hostId], references: [id])
  name        String
  city        String
  area        String
  category    String
  size        String
  price       Float
  description String   @db.Text
  photos      String[]
  features    String[]
  available   Boolean  @default(true)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  bookings    Booking[]
  reviews     Review[]
  reports     FieldReport[]

  @@map("shelves")
}

model Booking {
  id               String        @id @default(cuid())
  shelfId          String
  shelf            Shelf         @relation(fields: [shelfId], references: [id])
  vendorId         String
  vendor           User          @relation("VendorBookings", fields: [vendorId], references: [id])
  startDate        DateTime
  endDate          DateTime
  status           BookingStatus @default(PENDING)
  totalAmount      Float
  platformFee      Float
  hostPayout       Float
  productName      String
  productCategory  String?
  addOnMonitoring  Boolean       @default(false)
  addOnLogistics   Boolean       @default(false)
  notes            String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  payment          Payment?
  fieldReports     FieldReport[]
  logisticsJobs    LogisticsJob[]
  payout           Payout?

  @@map("bookings")
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  booking       Booking       @relation(fields: [bookingId], references: [id])
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  pesapalRef    String?
  pesapalTxn    String?
  stripeRef     String?
  ipnId         String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model FieldReport {
  id              String         @id @default(cuid())
  shelfId         String
  shelf           Shelf          @relation(fields: [shelfId], references: [id])
  bookingId       String
  booking         Booking        @relation(fields: [bookingId], references: [id])
  agentId         String
  agent           User           @relation("AgentReports", fields: [agentId], references: [id])
  visitDate       DateTime
  photos          String[]
  stockBefore     Int
  stockAfter      Int
  unitsSold       Int
  condition       ShelfCondition @default(GOOD)
  aiAnalysis      String?        @db.Text
  agentNotes      String?        @db.Text
  reportSent      Boolean        @default(false)
  createdAt       DateTime       @default(now())

  @@map("field_reports")
}

model LogisticsJob {
  id              String          @id @default(cuid())
  bookingId       String
  booking         Booking         @relation(fields: [bookingId], references: [id])
  agentId         String?
  agent           User?           @relation("AgentJobs", fields: [agentId], references: [id])
  pickupLocation  String
  busCompany      String?
  busWaybill      String?
  deliveryNotes   String?         @db.Text
  status          LogisticsStatus @default(PENDING)
  confirmedAt     DateTime?
  confirmPhoto    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("logistics_jobs")
}

model Payout {
  id          String       @id @default(cuid())
  hostId      String
  host        User         @relation(fields: [hostId], references: [id])
  bookingId   String?      @unique
  booking     Booking?     @relation(fields: [bookingId], references: [id])
  amount      Float
  status      PayoutStatus @default(PENDING)
  reference   String?
  processedAt DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("payouts")
}

model Review {
  id        String   @id @default(cuid())
  shelfId   String
  shelf     Shelf    @relation(fields: [shelfId], references: [id])
  vendorId  String
  vendor    User     @relation(fields: [vendorId], references: [id])
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([shelfId, vendorId])
  @@map("reviews")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}
